# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The URL of your Supabase project (e.g. https://your-project-id.supabase.co)
SUPABASE_URL="https://lrkzbnfkaoxozjjeqlvz.supabase.co"

# SUPABASE_SERVICE_ROLE_KEY: The secure service_role API key of your Supabase project.
# Used on the backend to bypass Row Level Security policies.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imxya3pibmZrYW94b3pqamVxbHZ6Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MTYwMzY0MSwiZXhwIjoyMDk3MTc5NjQxfQ.T6TiiIdrAIfeeXar5vpqiaZnc7VEiFT5Fh-41XWXpXE"

# PORT: The port the Express backend server should run on (defaults to 5000)
PORT=5000
